#!/usr/bin/env python3
# Resizes the column immediately to the right of the focused column to the
# complement of the focused column's width, so the two columns together span
# the working area exactly (no view shift when swapping focus between them).
# Does nothing if the focused column is at or near 100%.
#
# Niri's percentage widths are taken against working_width, where
#     working_width = screen_w - 2 * (gaps + border_width)
# (verified empirically: in tile mode with gaps=2, border=2, screen=1536,
#  set-column-width 60% produces tile_size = 916.8 = 0.60 * 1528.)
# Both gaps and border can differ between normal and tile mode, so they are
# read from the live niri config file at runtime.

import json, os, re, subprocess, sys

CONFIG_PATH = os.path.expanduser('~/.config/niri/config.kdl')

def niri(cmd):
    return json.loads(subprocess.run(['niri', 'msg', '--json'] + cmd, capture_output=True, text=True).stdout)

def read_layout_padding():
    """Return (gaps + border_width) in logical pixels — the per-side padding
    between the screen edge and a 100%-width tile."""
    with open(CONFIG_PATH) as f:
        text = f.read()

    m = re.search(r'(?m)^\s+gaps\s+(\d+)', text)
    gaps = int(m.group(1)) if m else 0

    # Find the border block and its (uncommented) width line. If the block
    # contains `off`, treat border as 0.
    border = 0
    bm = re.search(r'(?ms)^\s+border\s*\{(.*?)\}', text)
    if bm:
        block = bm.group(1)
        if not re.search(r'(?m)^\s*off\b', block):
            wm = re.search(r'(?m)^\s*width\s+(\d+)', block)
            if wm:
                border = int(wm.group(1))
    return gaps + border

wins    = niri(['windows'])
ws_data = niri(['workspaces'])
outputs = niri(['outputs'])

focused_ws_id = next((ws['id'] for ws in ws_data if ws['is_focused']), None)
if focused_ws_id is None:
    sys.exit(0)

screen_w = next(
    o['logical']['width'] for o in outputs.values() if o['logical'] is not None
)

focused = next((w for w in wins if w.get('is_focused')), None)
if focused is None or focused.get('is_floating'):
    sys.exit(0)

pos = focused['layout'].get('pos_in_scrolling_layout')
if pos is None:
    sys.exit(0)

focused_col = pos[0]
focused_tile_w = focused['layout']['tile_size'][0]

pad = read_layout_padding()
working_width = screen_w - 2 * pad

proportion = focused_tile_w / working_width

# Skip if focused column already fills the working area.
if proportion >= 0.99:
    sys.exit(0)

complement_pct = (1.0 - proportion) * 100

# Find one window in the column immediately to the right.
right_win = next(
    (w for w in wins
     if w.get('workspace_id') == focused_ws_id
     and not w.get('is_floating')
     and w['layout'].get('pos_in_scrolling_layout', [None])[0] == focused_col + 1),
    None
)

if right_win is None:
    sys.exit(0)

def niri_action(*args):
    subprocess.run(['niri', 'msg', 'action'] + list(args))

niri_action('focus-window', '--id', str(right_win['id']))
niri_action('set-column-width', f'{complement_pct:.6f}%')
niri_action('focus-window', '--id', str(focused['id']))
